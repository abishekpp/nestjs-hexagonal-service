model Workflow {
  id                String    @id @default(uuid())
  projectId         String
  subject           String
  documentIds       Json
  recipientIds      Json
  status            String    @default("IN_PROGRESS")
  dueDate           String?
  remarks           String?
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  completedAt       DateTime?
  transmittalId     String?
  transmittalNumber String?

  @@map("workflows")
}